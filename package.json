{
  "name": "dxtx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SQD file-store indexer for ERC20 transfer events across the dx-token-list universe",
  "scripts": {
    "clean": "npx --yes rimraf lib",
    "build": "npm run clean && tsc -p tsconfig.json",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:psql": "docker compose exec db psql -U ${DB_USER:-squid} -d ${DB_NAME:-dxtx_flows}",
    "process:all": "node --require=dotenv/config lib/all/publish.js",
    "process:ethereum": "node --require=dotenv/config lib/ethereum/publish.js",
    "process:base": "node --require=dotenv/config lib/base/publish.js",
    "process:arbitrum": "node --require=dotenv/config lib/arbitrum/publish.js",
    "process:optimism": "node --require=dotenv/config lib/optimism/publish.js",
    "process:polygon": "node --require=dotenv/config lib/polygon/publish.js",
    "process:avalanche": "node --require=dotenv/config lib/avalanche/publish.js",
    "process:unichain": "node --require=dotenv/config lib/unichain/publish.js",
    "process:bsc": "node --require=dotenv/config lib/bsc/publish.js",
    "build:flows": "node --require=dotenv/config lib/build-flows.js",
    "sync:flows": "node --require=dotenv/config lib/all/sync-flows.js",
    "sync:all": "node --require=dotenv/config lib/all/sync-all.js",
    "sync:labels": "node --require=dotenv/config lib/sync-labels.js",
    "inspect:flows": "node --require=dotenv/config lib/inspect-flows.js",
    "verify:flows": "node --require=dotenv/config lib/verify-flows.js",
    "check:cache": "node --require=dotenv/config lib/check-cache.js",
    "check:dataflow": "node --require=dotenv/config lib/check-dataflow.js",
    "check:freshness": "node --require=dotenv/config lib/check-freshness.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@duckdb/node-api": "^1.5.0-r.1",
    "@subsquid/evm-processor": "^1.29.0",
    "@subsquid/file-store": "^2.0.0",
    "@subsquid/file-store-parquet": "^1.1.1",
    "@subsquid/file-store-s3": "^2.0.1",
    "@types/pg": "^8.20.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
